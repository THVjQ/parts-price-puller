# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in.  .env is gitignored — secrets never leave the box.
#   cp .env.example .env && nano .env
# ─────────────────────────────────────────────────────────────────────────────

TZ=Australia/Sydney

# ── Site auth ───────────────────────────────────────────────────────────────
# password  = one shared account, session cookie (default)
# cf-access = Cloudflare Access in front; the app trusts its headers
# none      = open — LAN testing only, NEVER with a public hostname
AUTH_MODE=password
SITE_USER=SOSPhonerepairs
SITE_PASSWORD=1234

# Shared key for machine callers: the Willard scraper and the Tampermonkey script.
# Generate one:  openssl rand -hex 32
INGEST_KEY=change-me-long-random-string

# ── Supplier logins ─────────────────────────────────────────────────────────
CP_USER=your@crazyparts.login
CP_PASS=yourpassword

# ── Networking ──────────────────────────────────────────────────────────────
# Host port the site binds to. Cloudflare (tunnel or proxied DNS) points
# pricing.thvjq.com.au at this.
WEB_PORT=8084
# auto = mark the session cookie Secure only when the request arrived over https.
# Leave it on auto: a hard "1" makes login silently fail over plain http on the LAN.
SECURE_COOKIE=auto
# Optional — only used by the `cloudflare` compose profile.
CLOUDFLARE_TUNNEL_TOKEN=

# ── Live config from git (same pattern as the thvjq.com.au deployer) ────────
# 1 = the web container fetch+resets this repo on a timer, so editing config/*.yml
#     on GitHub updates the live site without a redeploy.
GIT_SYNC=1
GIT_SYNC_INTERVAL=120
GIT_BRANCH=main
GIT_REMOTE=https://github.com/THVjQ/parts-price-puller.git
# Only needed if the repo is private (fine-grained PAT with Contents: read).
GIT_TOKEN=

# GitHub push webhook → instant deploy instead of waiting for the poll.
#   openssl rand -hex 32   → paste here AND into the repo's webhook settings
#   Payload URL: https://pricing.thvjq.com.au/hooks/pricing
# Leave blank to disable signature checking (the endpoint then accepts anything —
# only do that on a LAN-only deployment).
WEBHOOK_SECRET=

# ── Scraper behaviour ───────────────────────────────────────────────────────
# 1 = run one pull immediately on container start (handy for testing)
RUN_NOW=
# 1 = after re-pricing every pin, also fuzzy-search the cells that have no pin.
# Off by default: fuzzy matching is exactly what the pin workflow replaced.
PULL_UNPINNED=
